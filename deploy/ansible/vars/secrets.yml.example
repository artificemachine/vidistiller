# =============================================================================
# Copy to secrets.yml and fill in your values
# Encrypt with: ansible-vault encrypt vars/secrets.yml
# DO NOT commit secrets.yml — it is gitignored
# =============================================================================

# Database
db_password: ""             # generate: openssl rand -hex 32

# Redis
redis_password: ""          # generate: openssl rand -hex 32

# FastAPI JWT signing key (32+ chars)
jwt_secret_key: ""          # generate: openssl rand -hex 32

# Fernet key for field encryption (API keys at rest)
field_encryption_key: ""    # generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# pgAdmin web UI
pgadmin_email: "admin@example.com"
pgadmin_password: ""        # generate: openssl rand -hex 16

# Timezone
timezone: "UTC"
