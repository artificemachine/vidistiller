#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"

# Backend tests (using project venv)
if [ -f "$REPO_ROOT/.venv/bin/python" ]; then
    echo "[pre-commit] Running backend tests..."
    PYTHONPATH="$REPO_ROOT/backend" "$REPO_ROOT/.venv/bin/python" -m pytest "$REPO_ROOT/tests/" -q --tb=short --ignore="$REPO_ROOT/tests/test_lxc_deploy.py" --ignore="$REPO_ROOT/tests/test_llm_vision_prepass.py"
else
    echo "[pre-commit] ⚠️  .venv not found — skipping backend tests (run: python3 -m venv .venv && pip install -e .)"
fi

# Frontend tests
if [ -d "$REPO_ROOT/frontend/node_modules" ]; then
    echo "[pre-commit] Running frontend tests..."
    (cd "$REPO_ROOT/frontend" && npm test -- --reporter=dot --retry=2)
else
    echo "[pre-commit] ⚠️  node_modules not found — skipping frontend tests (run: cd frontend && npm install)"
fi
