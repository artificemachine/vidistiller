{
  "version": 1,
  "mappings": [
    {
      "id": "youtube-model-feeder-ui",
      "penFile": "./youtube-model-feeder_ui_monokai.pen",
      "codeDir": "./frontend",
      "codeGlobs": ["components/**/*.tsx", "app/**/*.tsx", "app/**/*.css"],
      "framework": "nextjs",
      "styling": "tailwind",
      "direction": "both",
      "styleFiles": ["app/globals.css", "tailwind.config.js"]
    }
  ],
  "settings": {
    "debounceMs": 2000,
    "model": "claude-sonnet-4-6",
    "maxBudgetUsd": 0.50,
    "conflictStrategy": "prompt",
    "stateFile": ".pencil-sync-state.json",
    "logLevel": "info"
  }
}
