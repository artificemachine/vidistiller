# youtube-model-feeder — environment configuration
# Copy to .env and fill in your values:
#   cp .env.example .env

# ── Database ─────────────────────────────────────────────────────────────────
DB_USER=tutorial_user
DB_PASSWORD=changeme
DB_NAME=tutorial_db
DB_PORT=5432
DATABASE_URL=postgresql://tutorial_user:changeme@postgres:5432/tutorial_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ── Ollama (local LLM) ────────────────────────────────────────────────────────
# host.docker.internal lets containers reach Ollama running on your host machine
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3

# ── API ───────────────────────────────────────────────────────────────────────
API_PORT=8000
FRONTEND_PORT=3000
LXC_HOST=localhost
CORS_ORIGINS=["http://localhost:3000"]
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# Shared secret for machine-to-machine API clients (e.g. Semblar)
# Set to empty string to disable API key auth (JWT only)
VIDISTILLER_API_KEY=

# JWT secret — must be 32+ chars with upper, lower, digit, and special char
JWT_SECRET_KEY=ChangeMe123!ReplaceThisNow_32charsMin

# Fernet key for encrypting stored LLM API keys at rest
# Generate your own: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=Od7QDeptH2kG_z18FrkDMzwAxhBehzHNjrtwiMHwft4=

# ── Environment ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── Frontend ──────────────────────────────────────────────────────────────────
# pgAdmin — database GUI (http://localhost:5050)
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=changeme
PGADMIN_PORT=5050

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=your-email@gmail.com
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_STARTTLS=true
MAIL_SSL_TLS=false

# ── Password Reset ────────────────────────────────────────────────────────────
PASSWORD_RESET_EXPIRE_MINUTES=60
PASSWORD_RESET_URL=http://localhost:3000/reset-password

# ── Sentry (optional) ─────────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENABLED=false
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_DSN=

# ── vLLM GPU Fleet (on-prem sidecars on port 8100) ────────────────────────────
# Each entry is a vllm-manager sidecar URL. Leave blank to hide a VM from the UI.
VLLM_VM913_URL=http://10.255.150.36:8100
VLLM_VM903_URL=http://10.255.150.16:8100
VLLM_VM901_URL=http://10.255.150.10:8100
VLLM_VM2900_URL=http://10.255.150.20:8100
