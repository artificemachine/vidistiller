# Database Configuration
DB_USER=tutorial_user
DB_PASSWORD=tutorial_password
DB_NAME=tutorial_db
DB_PORT=5432
DATABASE_URL=postgresql://tutorial_user:tutorial_password@postgres:5432/tutorial_db

# Redis Configuration
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# Ollama Configuration
OLLAMA_PORT=11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# API Configuration
API_PORT=8000
FRONTEND_PORT=3000
CORS_ORIGINS=["http://localhost:3000"]
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# Security
JWT_SECRET_KEY=your-secret-key-change-in-production
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=your-fernet-key-here

# Environment
ENVIRONMENT=development

# pgAdmin Configuration
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# Email (SMTP) Configuration
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=your-email@gmail.com
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_STARTTLS=true
MAIL_SSL_TLS=false

# Password Reset
PASSWORD_RESET_EXPIRE_MINUTES=60
PASSWORD_RESET_URL=http://localhost:3000/reset-password

# Application Settings
LOG_LEVEL=INFO
MAX_WORKERS=4

# Sentry Error Monitoring (opt-in — leave SENTRY_ENABLED=false to disable)
SENTRY_DSN=
SENTRY_ENABLED=false
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_DSN=
