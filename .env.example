# youtube-model-feeder — environment configuration
# Copy to .env and fill in your values:
#   cp .env.example .env

# ── Database ─────────────────────────────────────────────────────────────────
DB_USER=tutorial_user
DB_PASSWORD=changeme
DB_NAME=tutorial_db
DB_PORT=5432
DATABASE_URL=postgresql://tutorial_user:changeme@postgres:5432/tutorial_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ── Ollama (local LLM) ────────────────────────────────────────────────────────
# host.docker.internal lets containers reach Ollama running on your host machine
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3

# Hosts permitted as a per-user LLM / vLLM endpoint. The backend fetches these
# from inside your network, so they are restricted to an allowlist rather than
# left open. Local endpoints are expected here, which is why this is an
# allowlist and not an IP-range check. Add your fleet hosts to widen it, e.g.
# ALLOWED_LLM_HOSTS=localhost,127.0.0.1,host.docker.internal,10.0.150.36
# Default covers loopback, the compose service names, and Docker's host alias.
# ALLOWED_LLM_HOSTS=localhost,127.0.0.1,::1,ollama,vllm,host.docker.internal

# Image tag docker-compose.prod.yml deploys. Unset means `latest`, which makes
# the running version unknowable from config and a rollback a guess. Pin it to a
# release (e.g. 1.10.16) so rolling back is a one-line change here.
# VIDISTILLER_IMAGE_TAG=

# ── API ───────────────────────────────────────────────────────────────────────
API_PORT=8000
FRONTEND_PORT=3000
STAGING_HOST=localhost
CORS_ORIGINS=["http://localhost:3000"]
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# Shared secret for machine-to-machine API clients (e.g. Semblar)
# Set to empty string to disable API key auth (JWT only)
VIDISTILLER_API_KEY=

# JWT secret. Either 32+ chars mixing upper, lower, digit and special char, or
# 64+ chars of generator output (the composition rules are waived at that length,
# so `openssl rand -hex 32` is accepted). SECRET_KEY is also read, for hosts
# configured before the two names were reconciled; JWT_SECRET_KEY wins.
# Left unset on purpose. With no value the app generates a random ephemeral key
# at startup, so local dev works straight after `cp .env.example .env` without a
# publicly-known secret ever signing a token. Tokens reset on restart.
# REQUIRED for ENVIRONMENT=production, and for any deployment where sessions
# must survive a restart. Generate one with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
# JWT_SECRET_KEY=

# Fernet key for encrypting stored LLM API keys at rest.
# The value below is a valid-but-public throwaway so `cp .env.example .env` boots
# for local dev. It is NOT secret — anyone can decrypt keys sealed with it.
# Generate your own before any real deployment:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=REVWLU9OTFktSU5TRUNVUkUtQ0hBTkdFLU1FLTAwMDA=

# ── Environment ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── Frontend ──────────────────────────────────────────────────────────────────
# pgAdmin — database GUI (http://localhost:5050)
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=changeme
PGADMIN_PORT=5050

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=your-email@gmail.com
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_STARTTLS=true
MAIL_SSL_TLS=false

# ── Password Reset ────────────────────────────────────────────────────────────
PASSWORD_RESET_EXPIRE_MINUTES=60
PASSWORD_RESET_URL=http://localhost:3000/reset-password

# ── Sentry (optional) ─────────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENABLED=false
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_DSN=

# ── vLLM GPU Fleet (direct vLLM on port 8000) ──────────────────────────────────
# Each entry is a vLLM server URL (port 8000 directly, NOT vllm-manager on 8100).
# vllm-manager on 8100 intercepts /v1/chat/completions as a model-swap signal.
# Leave blank to hide a VM from the UI.
VLLM_VM913_URL=http://10.0.150.36:8000
VLLM_VM903_URL=http://10.0.150.16:8000
VLLM_VM901_URL=http://10.0.150.10:8000
VLLM_VM2900_URL=http://10.0.150.20:8000
